# 의존성 (스크린샷 도구 — 재설치 가능)
node_modules/

# OS·에디터 부산물
Thumbs.db
.DS_Store
desktop.ini
.vscode/

# 로그·임시
*.log
.cache/

# ===== GitHub에는 "사이트 코드(html/css/js/gs)"만 올린다 =====
# 문서·기획·내부 설정은 로컬에만 두고 업로드 제외
# (gitignore는 줄 끝 주석을 지원하지 않으므로 패턴은 단독 줄로 둔다)

# 모든 마크다운(기획·계획·README·CLAUDE.md 등)
*.md
# 기획·전략 문서 + 크몽 이미지 생성기
docs/
# Claude Code 설정·에이전트
.claude/

# ===== 비공개 자산(GitHub 업로드 제외) =====
# 효과/스타일 카탈로그 (내부 레퍼런스)
_catalog/
# 엔진 마스터 전체(문의폼 IP + 공유 fx 라이브러리 마스터). 핵심 IP.
# 데모/고객 사이트는 필요한 파일만 자기 폴더로 vendoring(복사)해 공개 → 마스터는 비공개.
_engine/
# 히어로/로더/리빌 효과 쇼룸 (내부 효과 팔레트 — 다각화 소스, 절대 업로드 금지)
portfolio/works/hero-lab/
# 보류·폐기 변형 보관함
파킹랏/
# 고객 빌드 작업물(SITESPEC·납품 전 산출물 — 비공개)
projects/
# 내부 빌드/QA 자동화 툴(비공개 _engine 계약을 읽음 — 핵심 IP, 사이트 코드 아님)
scripts/
# 루트에 떨어진 스크린샷·잡 이미지(루트엔 코드만)
/*.png
